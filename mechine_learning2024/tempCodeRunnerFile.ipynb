import cv2
import dlib
from openface import OpenFace
 
# 初始化 OpenFace 模型
model = OpenFace()
 
# 读取图像
image = cv2.imread('sample.jpg')
 
# 进行面部关键点检测
landmarks = model.detect_landmarks(image)
 
# 显示结果
for (x, y) in landmarks:
    cv2.circle(image, (x, y), 2, (0, 255, 0), -1)
 
cv2.imshow('Landmarks', image)
cv2.waitKey(0)
cv2.destroyAllWindows()